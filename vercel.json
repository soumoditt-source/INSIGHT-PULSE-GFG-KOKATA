{
  "version": 2,
  "builds": [
    {
      "src": "frontend_extracted/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "InsightPulse_AI/backend.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "InsightPulse_AI/backend.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend_extracted/$1"
    }
  ]
}
